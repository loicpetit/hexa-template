type Query {
  user(id: ID!): UserView
}

type Mutation {
  addEmailToUser(userId: ID!, email: String!): UserView
  removeEmailFromUser(userId: ID!): UserView
  addUser(firstName: String!, name: String!): UserView
  deleteUser(id: ID!): Boolean!
}

type UserView {
  id: ID!
  firstName: String!
  name: String!
  modified: String
  email: EmailView
}

type EmailView {
  id: ID!
  value: String!
  modified: String
}
