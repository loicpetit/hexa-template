### Create email
POST http://{{emailBaseUrl}}
Authorization: Basic {{emailAuth.usr}} {{emailAuth.pwd}}
Content-Type: application/json

{
  "value": "bruce@kickass.com"
}

> {%
    const emailId = response.body
    client.log("email id", emailId)
    client.global.set("email-id", emailId)
%}

### Get email by id
GET http://{{emailBaseUrl}}/{{email-id}}
Authorization: Basic {{emailAuth.usr}} {{emailAuth.pwd}}

> {%
    const modified = response.body.modified
    client.log("modified", modified)
    client.global.set("email-modified", modified)
%}

### Get email by id - forbidden
GET http://{{emailBaseUrl}}/{{email-id}}
Authorization: Basic {{emailAuthForbidden.usr}} {{emailAuthForbidden.pwd}}

### Update email
PUT http://{{emailBaseUrl}}/{{email-id}}
Authorization: Basic {{emailAuth.usr}} {{emailAuth.pwd}}
Content-Type: application/json

{
  "value": "c.norris@kickass.com",
  "modified": "{{email-modified}}"
}
